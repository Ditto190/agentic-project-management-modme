{
  "name": "agentic-pm",
  "version": "1.0.1",
  "description": "Agentic Project Management CLI",
  "scripts": {
    "build": "node build/index.js",
    "build:release": "node build/index.js",
    "delivery:init": "bash delivery/_scripts/init-engagement.sh",
    "delivery:inbox": "bash delivery/_scripts/inbox-classifier.sh",
    "delivery:inbox:ai": "python3 delivery/_scripts/inbox-classifier.py",
    "delivery:status": "bash delivery/_scripts/status-rollup.sh",
    "delivery:validate": "bash delivery/_scripts/validate-frontmatter.sh",
    "delivery:tags": "bash delivery/_scripts/tag-manager.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sdi2200262/agentic-project-management.git"
  },
  "keywords": [
    "agentic",
    "project-management",
    "cli",
    "apm"
  ],
  "author": "CobuterMan <haidemenoss@gmail.com>",
  "contributors": [],
  "license": "MPL-2.0",
  "type": "module",
  "bin": {
    "apm": "src/index.js",
    "agentic-pm": "src/index.js"
  },
  "bugs": {
    "url": "https://github.com/sdi2200262/agentic-project-management/issues"
  },
  "homepage": "https://github.com/sdi2200262/agentic-project-management#readme",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@inquirer/prompts": "7.9.0",
    "@prisma/client": "^5.9.1",
    "@supabase/supabase-js": "^2.41.0",
    "adm-zip": "0.5.16",
    "axios": "1.14.0",
    "chalk": "5.6.2",
    "commander": "11.1.0",
    "fs-extra": "11.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "archiver": "^7.0.1",
    "js-yaml": "^4.1.1",
    "prisma": "^5.9.1"
  }
}
